# ---------------------------------------------------------------------------
# Copy this file to ".env.local" and fill in the values you have.
# The site works fine with NONE of these set (chat runs in offline mode).
# ---------------------------------------------------------------------------

# Anthropic API key — enables the LIVE Claude-powered chat.
# Without it, the chat falls back to in-browser retrieval mode automatically.
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Optional: override the chat model. Defaults to Claude Haiku (cheap + fast).
CHAT_MODEL=claude-haiku-4-5-20251001

# Your GitHub username — powers the live "Latest from GitHub" card on the page.
# This one is PUBLIC (NEXT_PUBLIC_ prefix), so only use your username here.
NEXT_PUBLIC_GITHUB_USERNAME=
